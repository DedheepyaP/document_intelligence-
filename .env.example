#  Secrets (required, no defaults) 
SECRET_KEY=your-long-random-secret-here
LLM_KEY=your-groq-api-key-here

#  Model / Vector store 
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
COLLECTION_NAME=docuchat_docs

#  Local development (override by Docker Compose for containers) 
DATABASE_URL=postgresql://docuuser:docupass@localhost:5432/docudb
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CHROMA_HOST=localhost
CHROMA_PORT=8001
UPLOAD_DIR=/tmp/uploads

#  CORS origins (comma-separated) 
# Local dev: http://localhost:5173
# Docker:    http://localhost,http://localhost:80  (set in compose.yaml)
ALLOWED_ORIGINS=http://localhost:5173

#  Token expiry 
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

#  Upload limits 
MAX_UPLOAD_SIZE_MB=20
